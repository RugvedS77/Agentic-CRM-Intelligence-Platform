                    "type": "string"
                  },
                  "classification": {
                    "type": "object"
                  },
                  "rag_context": {
                    "type": "array"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent plan",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentPlan"
                }
              }
            }
          }
        }
      }
    },
    "/agent/run": {
      "post": {
        "tags": ["Agent"],
        "summary": "Run the agent on an email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
