          }
        ],
        "responses": {
          "200": {
            "description": "List of threads",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Thread"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rag/search": {
      "get": {
        "tags": ["RAG"],
        "summary": "Search knowledge base",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RAGSearchResult"
                }
              }
            }
          }
        }
      }
    },
    "/classify": {
      "post": {
        "tags": ["Classifier"],
        "summary": "Classify an email",
