{
  "openapi": "3.0.0",
  "info": {
    "title": "SenAI CRM Intelligence Platform",
    "description": "Autonomous CRM triage system with RAG, LangGraph agents, and live web intelligence.",
    "version": "1.0.0",
    "contact": {
      "name": "SenAI Platform Team"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["Health"],
        "summary": "Root endpoint",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "SenAI CRM Intelligence Platform"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "healthy"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/db-health": {
      "get": {
        "tags": ["Health"],
        "summary": "Database health check",
        "responses": {
          "200": {
            "description": "Database is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "healthy"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ingest": {
      "post": {
        "tags": ["Ingestion"],
        "summary": "Ingest a single email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message_id", "sender", "subject", "body", "timestamp"],
                "properties": {
                  "message_id": {
                    "type": "string",
                    "description": "Unique email message ID"
                  },
                  "sender": {
                    "type": "string",
                    "format": "email",
                    "description": "Sender email address"
                  },
                  "subject": {
                    "type": "string",
                    "description": "Email subject"
                  },
                  "body": {
                    "type": "string",
                    "description": "Email body content"
                  },
                  "timestamp": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Email timestamp"
                  },
                  "thread_id": {
                    "type": "string",
                    "description": "Optional thread ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email ingested successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message_id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/stream/start": {
      "post": {
        "tags": ["Streaming"],
        "summary": "Start email streaming simulation",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "speed": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "description": "Speed multiplier (1-100)",
                    "default": 10
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Streaming started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "speed": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/threads/{thread_id}": {
      "get": {
        "tags": ["Threads"],
        "summary": "Get thread by ID",
        "parameters": [
          {
            "name": "thread_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Thread details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Thread"
                }
              }
            }
          },
          "404": {
            "description": "Thread not found"
          }
        }
      }
    },
    "/threads/{contact_email}": {
      "get": {
        "tags": ["Threads"],
        "summary": "Get all threads for a contact",
        "parameters": [
          {
            "name": "contact_email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
